{
  "name": "hugo-teek",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/add-frontmatter.js && hugo server --disableFastRender -D -F", 
    "server:prod": "bash scripts/start.sh",
    "build": "hugo --gc --minify -D -F",
    "build:log": "hugo --gc --minify -D -F --logLevel debug",
    "build:prod": "bash scripts/build.sh",
    "clean": "rm -rf resources dist .edgeone",
    "proxy": "node scripts/proxy.js",
    "update": "hugo mod get ./...",
    "deploy": "yarn run clean && edgeone pages deploy -n hugo"
  },
  "keywords": [
    "hugo"
  ],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "autoprefixer": "^10.4.22",
    "echarts": "^6.0.0",
    "gray-matter": "^4.0.3",
    "http-proxy": "^1.18.1",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1"
  }
}
